.nh
.TH "GO-FDO-CLIENT-DEVICE-INIT" "1" "go-fdo-client" "Go FDO Client"

.SH NAME
go-fdo-client-device-init - Run device initialization (DI)


.SH SYNOPSIS
\fBgo-fdo-client device-init [server-url] [flags]\fP


.SH DESCRIPTION
Run device initialization (DI) to register the device with a manufacturer server.
The server URL can be provided as a positional argument, flag or via config file.
At least one of --blob or --tpm is required to store device credentials.


.SH OPTIONS
\fB--device-info\fP=""
	Device information for device credentials, if not specified, it'll be gathered from the system

.PP
\fB--device-info-mac\fP=""
	Mac-address's iface e.g. eth0 for device credentials

.PP
\fB-h\fP, \fB--help\fP[=false]
	help for device-init

.PP
\fB--insecure-tls\fP[=false]
	Skip TLS certificate verification

.PP
\fB--key-enc\fP="x509"
	Public key encoding to use for manufacturer key [x509,x5chain,cose]

.PP
\fB--serial-number\fP=""
	Serial number for device credentials, if not specified, it'll be gathered from the system


.SH OPTIONS INHERITED FROM PARENT COMMANDS
\fB--blob\fP=""
	File path of device credential blob

.PP
\fB--config\fP=""
	Path to configuration file (YAML or TOML)

.PP
\fB--debug\fP[=false]
	Print HTTP contents

.PP
\fB--key\fP=""
	Key type for device credential [options: ec256, ec384, rsa2048, rsa3072]

.PP
\fB--tpm\fP=""
	Use a TPM at path for device credential secrets


.SH EXAMPLE
.EX

  # Using CLI arguments:
  go-fdo-client device-init http://127.0.0.1:8038 --key ec256 --blob cred.bin

  # Using config file:
  go-fdo-client device-init --config config.yaml

  # Mix CLI and config (CLI takes precedence):
  go-fdo-client device-init http://127.0.0.1:8038 --config config.yaml --key ec384
.EE


.SH SEE ALSO
\fBgo-fdo-client(1)\fP
